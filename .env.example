# Service
ENV=dev
SERVICE_NAME=continuum-riot-core

# API
HOST=127.0.0.1
PORT=8000

# Database (async runtime DSN)
DATABASE_URL=postgresql+asyncpg://riotcore:CHANGE_ME@127.0.0.1:5432/riotcore

# Database (sync DSN for Alembic migrations)
DATABASE_URL_SYNC=postgresql+psycopg://riotcore:CHANGE_ME@127.0.0.1:5432/riotcore

# Riot + DDragon
RIOT_API_KEY=REPLACE_WITH_DEV_KEY
DDDRAGON_BASE_URL=https://ddragon.leagueoflegends.com
DDDRAGON_DATA_DIR=/mnt/continuum/Projects/continuum-riot-core/data/ddragon